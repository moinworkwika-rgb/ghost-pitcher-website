<script>
  // ===== BACKGROUND =====
  const bgCanvas = document.getElementById('bg-canvas');
  const bgCtx = bgCanvas.getContext('2d');
  let bgW, bgH, bgDpr;
  function sizeBG() {
    bgDpr = Math.min(window.devicePixelRatio || 1, 2);
    bgW = bgCanvas.width = window.innerWidth * bgDpr;
    bgH = bgCanvas.height = window.innerHeight * bgDpr;
    bgCanvas.style.width = window.innerWidth + 'px';
    bgCanvas.style.height = window.innerHeight + 'px';
  }
  sizeBG();
  window.addEventListener('resize', sizeBG);

  let bgMouse = { x: innerWidth/2, y: innerHeight/2, tx: innerWidth/2, ty: innerHeight/2, active: 0 };
  const orbs = [
    { baseX: 0.15, baseY: 0.6, r: 0.6, hue: 158, sat: 80, light: 24, speed: 0.0004, phase: 0.0 },
    { baseX: 0.85, baseY: 0.25, r: 0.5, hue: 165, sat: 70, light: 20, speed: 0.0006, phase: 1.2 },
    { baseX: 0.5, baseY: 0.95, r: 0.55, hue: 152, sat: 65, light: 18, speed: 0.0003, phase: 2.4 },
    { baseX: 0.95, baseY: 0.75, r: 0.4, hue: 170, sat: 75, light: 22, speed: 0.0007, phase: 3.6 },
    { baseX: 0.05, baseY: 0.1, r: 0.35, hue: 148, sat: 60, light: 14, speed: 0.0005, phase: 4.8 },
    { baseX: 0.7, baseY: 0.5, r: 0.3, hue: 160, sat: 55, light: 12, speed: 0.0008, phase: 5.6 },
  ];
  const particles = [];
  for (let i = 0; i < 30; i++) {
    particles.push({
      x: Math.random(), y: Math.random(),
      vx: (Math.random() - 0.5) * 0.0002,
      vy: (Math.random() - 0.5) * 0.0002,
      r: Math.random() * 1.5 + 0.3,
      alpha: Math.random() * 0.3 + 0.05,
    });
  }
  let bgT = 0;
  function drawBG() {
    bgT += 1;
    bgMouse.x += (bgMouse.tx - bgMouse.x) * 0.04;
    bgMouse.y += (bgMouse.ty - bgMouse.y) * 0.04;
    bgMouse.active *= 0.99;

    bgCtx.fillStyle = '#040604';
    bgCtx.fillRect(0, 0, bgW, bgH);

    orbs.forEach(orb => {
      const elX = Math.sin(bgT * orb.speed + orb.phase) * 0.12;
      const elY = Math.cos(bgT * orb.speed * 1.3 + orb.phase) * 0.10;
      const pullX = (bgMouse.x/innerWidth - orb.baseX) * 0.15 * bgMouse.active;
      const pullY = (bgMouse.y/innerHeight - orb.baseY) * 0.15 * bgMouse.active;
      const cx = (orb.baseX + elX + pullX) * bgW;
      const cy = (orb.baseY + elY + pullY) * bgH;
      const radius = (orb.r + Math.sin(bgT*0.002 + orb.phase) * 0.05) * Math.max(bgW, bgH);
      const g = bgCtx.createRadialGradient(cx, cy, 0, cx, cy, radius);
      g.addColorStop(0, `hsla(${orb.hue}, ${orb.sat}%, ${orb.light}%, 0.85)`);
      g.addColorStop(0.35, `hsla(${orb.hue}, ${orb.sat}%, ${orb.light * 0.6}%, 0.4)`);
      g.addColorStop(1, `hsla(${orb.hue}, ${orb.sat}%, 0%, 0)`);
      bgCtx.fillStyle = g;
      bgCtx.fillRect(0, 0, bgW, bgH);
    });

    bgCtx.fillStyle = 'rgba(180, 255, 210, 0.5)';
    particles.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0) p.x += 1; if (p.x > 1) p.x -= 1;
      if (p.y < 0) p.y += 1; if (p.y > 1) p.y -= 1;
      bgCtx.globalAlpha = p.alpha;
      bgCtx.beginPath();
      bgCtx.arc(p.x * bgW, p.y * bgH, p.r * bgDpr, 0, Math.PI*2);
      bgCtx.fill();
    });
    bgCtx.globalAlpha = 1;

    const v = bgCtx.createRadialGradient(bgW/2, bgH/2, Math.min(bgW,bgH)*0.25, bgW/2, bgH/2, Math.max(bgW,bgH)*0.75);
    v.addColorStop(0, 'rgba(0,0,0,0)');
    v.addColorStop(1, 'rgba(0,0,0,0.75)');
    bgCtx.fillStyle = v;
    bgCtx.fillRect(0, 0, bgW, bgH);

    requestAnimationFrame(drawBG);
  }
  drawBG();

  const cursorDot = document.getElementById('cursor-dot');
  let mouseX = innerWidth / 2, mouseY = innerHeight / 2;
  let dotX = mouseX, dotY = mouseY;

  document.addEventListener('mousemove', e => {
    bgMouse.tx = e.clientX; bgMouse.ty = e.clientY;
    bgMouse.active = Math.min(bgMouse.active + 0.02, 1);
    mouseX = e.clientX;
    mouseY = e.clientY;
  });

  function animateCursorDot() {
    dotX += (mouseX - dotX) * 0.18;
    dotY += (mouseY - dotY) * 0.18;
    cursorDot.style.left = dotX + 'px';
    cursorDot.style.top = dotY + 'px';
    requestAnimationFrame(animateCursorDot);
  }
  animateCursorDot();

  // ===== LOADING SCREEN =====
  const loader = document.getElementById('loader');
  const loaderFill = document.getElementById('loader-fill');
  const loaderBarFill = document.getElementById('loader-bar-fill');
  const loaderPct = document.getElementById('loader-pct');
  const loaderGhost = document.getElementById('loader-ghost');

  let loadProgress = 0;
  // Animate progress — simulated load, will complete after window load
  const pageLoadStart = performance.now();
  let windowLoaded = false;
  window.addEventListener('load', () => { windowLoaded = true; });

  function updateLoader() {
    // smooth progress: grows to ~90% on its own, then jumps to 100 once page loaded
    const elapsed = performance.now() - pageLoadStart;
    let target;
    if (!windowLoaded) {
      target = Math.min(90, (elapsed / 1200) * 90);
    } else {
      target = 100;
    }
    loadProgress += (target - loadProgress) * 0.08;

    loaderBarFill.style.width = loadProgress + '%';
    loaderPct.textContent = Math.floor(loadProgress) + '%';
    // Fill rises inside ghost silhouette from y=850 (below) to y=0 (top of bbox)
    // Rect is y=... width=650 height=850 clipped by ghost-clip
    // We want fill height = loadProgress%; rect starts at y = 850 - fillHeight
    const fillHeight = (loadProgress / 100) * 830;
    loaderFill.setAttribute('y', 850 - fillHeight);
    loaderFill.setAttribute('height', fillHeight);

    if (loadProgress >= 99.5) {
      loader.style.display = 'none';
      document.body.classList.remove('loading');
      return;
    }
    requestAnimationFrame(updateLoader);
  }
  requestAnimationFrame(updateLoader);

  function startFlyOut() {
    // measure loader ghost center vs target cursor start position
    const rect = loaderGhost.getBoundingClientRect();
    const startX = rect.left + rect.width / 2;
    const startY = rect.top + rect.height / 2;
    // target: center of screen (user hasn't moved yet) — it'll then follow mouse once they interact
    const targetX = innerWidth / 2;
    const targetY = innerHeight / 2;

    // animate loader ghost flying to target while scaling down
    const startScale = 1;
    const endScale = 1; // cursor width 56 vs loader width 180
    const duration = 900;
    const flyStart = performance.now();

    // fade out the bar + pct immediately
    document.querySelector('.loader-bar').style.transition = 'opacity 0.3s ease';
    document.querySelector('.loader-bar').style.opacity = '0';
    loaderPct.style.transition = 'opacity 0.3s ease';
    loaderPct.style.opacity = '0';
    loader.style.background = 'transparent';
    loader.style.transition = 'none';

    function ease(t) { return t < 0.5 ? 2*t*t : 1 - Math.pow(-2*t+2,2)/2; } // easeInOutQuad

    function fly(now) {
      const t = Math.min((now - flyStart) / duration, 1);
      const e = ease(t);
      const x = startX + (targetX - startX) * e;
      const y = startY + (targetY - startY) * e;
      const s = startScale + (endScale - startScale) * e;
      loaderGhost.style.position = 'fixed';
      loaderGhost.style.left = x + 'px';
      loaderGhost.style.top = y + 'px';
      loaderGhost.style.transform = `translate(-50%, -50%) scale(${s})`;
      if (t < 1) requestAnimationFrame(fly);
      else {
        // hand off to real cursor
        loader.style.display = 'none';
        document.body.classList.remove('loading');
        // position real cursor at center immediately (user will move from there)
        mouseX = targetX;
        mouseY = targetY;
        gx = targetX; gy = targetY;
      }
    }
    requestAnimationFrame(fly);
  }

  // ===== NAV =====
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (scrollY > 40) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  });

  // ===== CLIENT LOGOS =====
  const clients = [
    { name: 'Mercedes-Benz', logo: 'mercedes.svg', fallback: 'mercedes.png' },
    { name: 'Ford', logo: 'ford.svg', fallback: 'ford.png' },
    { name: 'Audi', logo: 'audi.svg', fallback: 'audi.png' },
    { name: 'Volkswagen', logo: 'vw.svg', fallback: 'vw.png' },
    { name: 'BMW Mini', logo: 'mini.svg', fallback: 'mini.png' },
    { name: 'Citroën', logo: 'citroen.svg', fallback: 'citroen.png' },
    { name: 'Opel', logo: 'opel.svg', fallback: 'opel.png' },
    { name: 'MAN', logo: 'man.svg', fallback: 'man.png' },
    { name: 'Sixt', logo: 'sixt.svg', fallback: 'sixt.png' },
    { name: 'Deutsche Bahn', logo: 'db.svg', fallback: 'db.png' },
    { name: 'Samsung', logo: 'samsung.svg', fallback: 'samsung.png' },
    { name: 'Sony', logo: 'sony.svg', fallback: 'sony.png' },
    { name: 'Siemens', logo: 'siemens.svg', fallback: 'siemens.png' },
    { name: 'Braun', logo: 'braun.svg', fallback: 'braun.png' },
    { name: 'Saturn', logo: 'saturn.svg', fallback: 'saturn.png' },
    { name: 'ZDF', logo: 'zdf.svg', fallback: 'zdf.png' },
    { name: 'Audible', logo: 'audible.svg', fallback: 'audible.png' },
    { name: 'Peloton', logo: 'peloton.svg', fallback: 'peloton.png' },
    { name: "McDonald's", logo: 'mcdonalds.svg', fallback: 'mcdonalds.png' },
    { name: 'Burger King', logo: 'burgerking.svg', fallback: 'burgerking.png' },
    { name: 'Pepsi', logo: 'pepsi.svg', fallback: 'pepsi.png' },
    { name: 'Nutella', logo: 'nutella.svg', fallback: 'nutella.png' },
    { name: 'Kinder', logo: 'kinder.svg', fallback: 'kinder.png' },
    { name: 'Jägermeister', logo: 'jägermeister.svg', fallback: 'jagermeister.png' },
    { name: 'Jever', logo: 'jever.svg', fallback: 'jever.png' },
    { name: 'Nivea', logo: 'nivea.svg', fallback: 'nivea.png' },
    { name: 'Schwarzkopf', logo: 'schwarzkopf.svg', fallback: 'schwarzkopf.png' },
    { name: 'Commerzbank', logo: 'commerzbank.svg', fallback: 'commerzbank.png' },
  ];
  const grid = document.getElementById('clients-grid');
  clients.forEach(c => {
    const cell = document.createElement('div');
    cell.className = 'client-cell';
    cell.innerHTML = `
      <img src="assets/clients/${c.logo}" alt="${c.name} logo" loading="lazy" />
      <div class="fallback" hidden>${c.name}</div>
    `;

    const img = cell.querySelector('img');
    const fallback = cell.querySelector('.fallback');
    img.addEventListener('error', () => {
      if (img.dataset.fallbackApplied === 'true') {
        img.remove();
        fallback.hidden = false;
        return;
      }
      img.dataset.fallbackApplied = 'true';
      img.src = `assets/clients/${c.fallback}`;
    });

    grid.appendChild(cell);
    cell.addEventListener('mousemove', e => {
      const r = cell.getBoundingClientRect();
      cell.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
      cell.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
    });
  });

  // ===== PROD HOUSES =====
  const prodHouses = [
    'BWGTBLD', 'Rabbicorn', 'Tempomedia', 'Saltwater Films', 'The Marmalade',
    'Markenfilm', 'TRUEmates', 'Maya Impression', 'EASYdoesit', 'Soulworx',
    'Bakery Films', 'Mona Film', 'E+P Films', 'Rejell', 'Chunk',
    'MediaMonks', 'Congaz Visual Media', 'Infected', 'Foxdevilfilms', 'Cobblestone',
    'cndy film', 'AKKURAT', 'Soup.film', 'Markenfilm Switzerland', 'Tony Petersen Film',
    'Shining Film', 'MMAATTCCHH', 'Element E', 'Markenfilm Asia', 'Rabbicorn Films',
    'Stink', "It's Us", 'Zauberberg', '27 Kilometer', 'IAM Image',
    'Kleine Brüder', 'Markenfilm Crossing', 'Erste Liebe', 'Markenfilm Berlin',
    'Ziegler Film', 'Sterntag Film'
  ];
  const prodList = document.getElementById('prod-list');
  prodHouses.forEach((name, i) => {
    const span = document.createElement('span');
    span.textContent = name;
    prodList.appendChild(span);
    if (i < prodHouses.length - 1) {
      const sep = document.createElement('span');
      sep.className = 'sep';
      sep.textContent = '·';
      prodList.appendChild(sep);
    }
  });

  // ===== REVEAL =====
  const revealEls = document.querySelectorAll('.case, .service, .reel-card, .ai-sample, .client-cell, .section-header h2');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  revealEls.forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(30px)';
    el.style.transition = `opacity 1s cubic-bezier(0.7,0,0.3,1) ${(i % 6) * 0.04}s, transform 1s cubic-bezier(0.7,0,0.3,1) ${(i % 6) * 0.04}s`;
    io.observe(el);
  });

  // magnetic CTA
  document.querySelectorAll('.cta-btn').forEach(btn => {
    btn.addEventListener('mousemove', (e) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
    });
    btn.addEventListener('mouseleave', () => { btn.style.transform = ''; });
  });
</script>

